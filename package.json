{
  "name": "llm-whisper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Whisper to free web LLM chat UIs (Qwen, ChatGPT, Claude, DeepSeek, GLM) and expose them over one local HTTP API.",
  "bin": {
    "whisper": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts serve",
    "serve": "tsx src/cli.ts serve",
    "login": "tsx src/cli.ts login",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js serve",
    "chrome": "google-chrome --remote-debugging-port=9222 --user-data-dir=$HOME/.config/llm-whisper-chrome --no-first-run"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "playwright": "^1.49.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "ignoredBuiltDependencies": ["@anthropic-ai/claude-code"],
    "onlyBuiltDependencies": ["puppeteer-extra-plugin-stealth"]
  }
}

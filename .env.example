# Port the local API server listens on
PORT=9777

# Where persistent browser profiles (logged-in sessions) are stored.
# Defaults to ~/.config/llm-whisper/profiles when unset.
# PROFILES_DIR=./profiles

# Run browsers headless (true) or with a visible window (false).
# Keep false while getting started so you can see it work.
HEADLESS=false

# Optional API key. When set, every endpoint except GET /health requires it,
# passed as `Authorization: Bearer <key>` or `x-api-key: <key>`.
# Leave unset/commented for an open API (fine for localhost).
# WHISPER_API_KEY=change-me

# --- CDP mode (recommended): connect to YOUR real Chrome ---
# 1. Start Chrome with: pnpm run chrome
#    (this opens your real Chrome with all your Google accounts)
# 2. Set CDP_URL here:
# CDP_URL=http://localhost:9222
#
# Leave CDP_URL unset to use profile mode (isolated Playwright Chromium,
# requires pnpm run login <provider> once per service).

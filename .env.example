# Port the local API server listens on
PORT=9777

# Where persistent browser profiles (logged-in sessions) are stored.
# Defaults to ~/.config/llm-whisperer/profiles when unset.
# PROFILES_DIR=./profiles

# Run browsers headless (true) or with a visible window (false).
# Keep false while getting started so you can see it work.
HEADLESS=false

# Which browser the profile-mode launcher uses.
#   chromium (default) — Playwright's bundled Chromium, zero install.
#   chrome             — your locally-installed Google Chrome. Recommended:
#                        passes Google's "this browser may not be secure" login
#                        check that the bundled Chromium often fails.
#   msedge             — locally-installed Microsoft Edge.
# (Ignored in CDP mode — there the browser is whatever you started.)
# BROWSER=chrome

# Optional API key. When set, every endpoint except GET /health requires it,
# passed as `Authorization: Bearer <key>` or `x-api-key: <key>`.
# Leave unset/commented for an open API (fine for localhost).
# WSPR_API_KEY=change-me

# --- Real provider API keys (OpenAI-compatible) ---
# Set these to use the API-key providers in providers.yaml (openai, deepseek-api,
# …) which call the real HTTP API instead of driving a browser. The env var name
# must match the provider's `keyEnv`. Each is only needed if you use that provider.
# OPENAI_API_KEY=sk-...     # paid — https://platform.openai.com/api-keys
# DEEPSEEK_API_KEY=sk-...   # paid — https://platform.deepseek.com/api_keys
# GEMINI_API_KEY=...        # free tier — https://aistudio.google.com/apikey
# GROQ_API_KEY=...          # free tier — https://console.groq.com/keys
# OPENROUTER_API_KEY=...    # free models — https://openrouter.ai/keys
# CEREBRAS_API_KEY=...      # free tier — https://cloud.cerebras.ai
# MISTRAL_API_KEY=...       # free tier — https://admin.mistral.ai/organization/api-keys
# Cloudflare Workers AI needs BOTH a token and your account id (used in the URL).
# dash.cloudflare.com -> AI -> AI Gateway -> "Create Authentication Token":
# CLOUDFLARE_API_TOKEN=...    # the token from that button
# CLOUDFLARE_ACCOUNT_ID=...   # the <ACCOUNT_ID> shown in the sample curl on that page

# --- CDP mode (recommended): connect to YOUR real Chrome ---
# 1. Start Chrome with: pnpm run chrome
#    (this opens your real Chrome with all your Google accounts)
# 2. Set CDP_URL here:
# CDP_URL=http://localhost:9222
#
# Leave CDP_URL unset to use profile mode (isolated Playwright Chromium,
# requires pnpm run login <provider> once per service).
